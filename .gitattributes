# 모든 텍스트 파일은 저장소에 LF로 저장, 체크아웃 시 OS 기본값 사용
* text=auto eol=lf

# 명시적 텍스트 파일
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.html text eol=lf
*.env* text eol=lf

# 바이너리 파일 (줄바꿈 변환 안 함)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
